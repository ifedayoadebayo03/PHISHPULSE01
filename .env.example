# PhishPulse Configuration

# Security
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///./phishpulse.db

# API Configuration
API_V1_STR=/api/v1

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Model Paths
URL_MODEL_PATH=models/url_isolation_forest.pkl.gz
EMAIL_MODEL_PATH=models/email_nb_model.pkl
VISUAL_HASHES_DB=models/visual_hashes.db

# Risk Thresholds
THRESHOLD_CLEAN=30
THRESHOLD_SUSPICIOUS=60
THRESHOLD_MALICIOUS=85

# External APIs (optional)
PHISHTANK_API_KEY=
WHOIS_API_KEY=
